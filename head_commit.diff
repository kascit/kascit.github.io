diff --git a/templates/macros/post_card.html b/templates/macros/post_card.html
new file mode 100644
index 0000000..f3f2003
--- /dev/null
+++ b/templates/macros/post_card.html
@@ -0,0 +1,47 @@
+{% macro render(post) %}
+<article class="relative flex flex-col p-5 sm:p-6 border border-base-content/10 rounded-xl bg-base-100 transition-all duration-300 hover:border-base-content/25 hover:shadow-md hover:-translate-y-[2px] group">
+    <a href="{{ post.permalink | safe }}" class="absolute inset-0 z-10"><span class="sr-only">Read {{ post.title }}</span></a>
+    
+    <div class="flex flex-col gap-2.5">
+        <h3 class="text-xl font-bold text-base-content m-0 leading-tight group-hover:text-primary transition-colors">
+            {{ post.title }}
+        </h3>
+        
+        {% if post.description %}
+        <p class="text-sm text-base-content/75 m-0 line-clamp-2 leading-relaxed">
+            {{ post.description }}
+        </p>
+        {% endif %}
+        
+        <div class="flex items-center justify-between mt-1">
+            <div class="flex items-center gap-3 text-xs font-medium text-base-content/50">
+                {% if post.date %}
+                <time datetime="{{ post.date }}" class="font-mono">{{ post.date | date(format="%Y-%m-%d") }}</time>
+                {% endif %}
+            </div>
+            <div class="text-xs font-semibold text-primary opacity-0 -translate-x-2 transition-all duration-300 group-hover:opacity-100 group-hover:translate-x-0 flex items-center gap-1">
+                Read <i class="fa-solid fa-arrow-right text-[10px]"></i>
+            </div>
+        </div>
+    </div>
+
+    {% if post.taxonomies %}
+    <div class="mt-4 pt-4 border-t border-base-content/5 flex flex-wrap gap-2 relative z-20">
+        {% if post.taxonomies.categories %}
+            {% for cat in post.taxonomies.categories %}
+            <a href="{{ get_taxonomy_url(kind='categories', name=cat) }}" class="inline-flex items-center px-2.5 py-1 rounded-md text-[10px] font-bold tracking-wider uppercase bg-base-content/5 text-base-content/80 border border-base-content/10 hover:bg-base-content/10 hover:text-base-content transition-colors">
+                {{ cat }}
+            </a>
+            {% endfor %}
+        {% endif %}
+        {% if post.taxonomies.tags %}
+            {% for tag in post.taxonomies.tags %}
+            <a href="{{ get_taxonomy_url(kind='tags', name=tag) }}" class="inline-flex items-center px-2.5 py-1 rounded-md text-[11px] font-medium bg-transparent text-base-content/60 border border-base-content/15 hover:border-base-content/30 hover:text-base-content transition-colors before:content-['#'] before:opacity-40 before:mr-0.5">
+                {{ tag }}
+            </a>
+            {% endfor %}
+        {% endif %}
+    </div>
+    {% endif %}
+</article>
+{% endmacro render %}
